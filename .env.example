# Shared HS256 secret: the auth service signs access tokens with it and the
# support-telegram service verifies them (generate: openssl rand -hex 32).
SUPPORT_JWT_SECRET=replace-with-long-random-secret

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token

# Your personal Telegram chat id (get it from @userinfobot).
# Support messages from the app are delivered to this chat.
TELEGRAM_CHAT_ID=replace-with-your-chat-id

# Telegram Gateway token (https://gateway.telegram.org) — delivers OTP codes
# to any phone number with a Telegram account, no bot registration required.
# Paid: about $0.01 per delivered code. Optional.
#AUTH_TELEGRAM_GATEWAY_TOKEN=

# Separate login bot (also from @BotFather) that delivers OTP codes to users
# who shared their phone number with it. Optional fallback: used when the
# Gateway is not configured or fails; after that codes go via sms.ru
# (if configured) or to the auth service log (dev mode).
#AUTH_TELEGRAM_BOT_TOKEN=

# Your domain pointing to this server. Leave unset to serve plain HTTP on :80
# (works only with debug builds of the app). With a domain set, Caddy obtains
# a Let's Encrypt certificate automatically.
#DOMAIN=your-domain.ru
